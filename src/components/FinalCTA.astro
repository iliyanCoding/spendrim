---
import SectionLabel from './SectionLabel.astro';
---

<section id="book" class="border-t border-rule py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6 sm:px-10">
    <SectionLabel index="08" label="Start here" />

    <div class="mt-8 grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-20">
      <div>
        <h2 class="display max-w-md text-[2.5rem] leading-[1.02] sm:text-[3.5rem]">
          Stop <em class="display-italic">bleeding</em> on AI costs.
        </h2>
        <p class="mt-6 max-w-sm text-lg leading-relaxed text-ink-soft">
          Request a free waste audit. You'll leave with at least one concrete number — whether or not we
          ever work together. No deck, no pitch.
        </p>
        <p class="mt-8 text-sm text-ink-faint">
          or email <a href="mailto:hello@spendrim.com" class="border-b border-rule text-ink transition-colors hover:border-accent hover:text-accent">hello@spendrim.com</a>
        </p>
      </div>

      <div>
        <form id="cta-form" action="https://formspree.io/f/mpqvpnje" method="POST" class="space-y-7">
          <input type="hidden" name="_subject" value="Waste audit request - spendrim.com" />
          <div>
            <label for="cta-name" class="label block text-ink-faint">Name</label>
            <input
              id="cta-name"
              type="text"
              name="name"
              required
              autocomplete="name"
              placeholder="Jane Doe"
              class="mt-2 w-full border-b border-ink bg-transparent pb-2 text-ink placeholder:text-ink-faint/60 focus:border-accent focus:outline-none"
            />
          </div>
          <div>
            <label for="cta-email" class="label block text-ink-faint">Work email</label>
            <input
              id="cta-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="jane@company.com"
              class="mt-2 w-full border-b border-ink bg-transparent pb-2 text-ink placeholder:text-ink-faint/60 focus:border-accent focus:outline-none"
            />
          </div>
          <div>
            <label for="cta-message" class="label block text-ink-faint">
              What are you running, roughly what does it cost?
            </label>
            <textarea
              id="cta-message"
              name="message"
              rows="2"
              placeholder="e.g. GPT-4 + Claude, ~$20k/mo across a support bot and a doc pipeline"
              class="mt-2 w-full resize-none border-b border-ink bg-transparent pb-2 text-ink placeholder:text-ink-faint/60 focus:border-accent focus:outline-none"></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-accent px-6 py-3.5 font-medium text-paper transition-colors hover:bg-accent-deep disabled:cursor-not-allowed disabled:opacity-60"
          >
            Request my free audit
          </button>
          <p id="cta-error" hidden class="text-sm text-accent-deep">
            Something went wrong. Please try again, or email us directly.
          </p>
        </form>
        <div id="cta-success" hidden class="border-t-2 border-ink pt-5">
          <p class="display text-xl">Request received.</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">
            We'll reply within one business day with a couple of questions and a time to talk.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement;
  const success = document.getElementById('cta-success')!;
  const error = document.getElementById('cta-error')!;

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = form.querySelector('button')!;
    button.disabled = true;
    error.hidden = true;

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) throw new Error(`Formspree responded ${response.status}`);
      form.hidden = true;
      success.hidden = false;
    } catch {
      error.hidden = false;
      button.disabled = false;
    }
  });
</script>

---
import { Icon } from 'astro-icon/components';
---

<section id="book" class="border-t border-edge py-20 sm:py-28">
  <div class="mx-auto max-w-4xl px-5 text-center sm:px-8">
    <h2 class="text-3xl font-semibold tracking-tight sm:text-5xl" data-reveal>
      Stop bleeding on AI costs.
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-lg text-mist" data-reveal style="--reveal-delay: 100ms">
      Request a free waste audit. You'll leave with at least one concrete number - whether or not we ever
      work together.
    </p>

    <div
      class="mx-auto mt-10 max-w-lg rounded-xl border border-edge bg-surface p-8"
      data-reveal
      style="--reveal-delay: 200ms"
    >
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-lg bg-raised text-accent">
        <Icon name="lucide:search-check" class="h-6 w-6" />
      </div>
      <p class="mt-4 font-semibold">Free Waste Audit</p>
      <p class="mt-1 text-sm text-mist">No deck, no pitch. We look at your usage and point at the waste.</p>
      <form id="cta-form" action="https://formspree.io/f/mpqvpnje" method="POST" class="mt-6 space-y-4 text-left">
        <input type="hidden" name="_subject" value="Waste audit request - spendrim.com" />
        <div>
          <label for="cta-name" class="mb-1.5 block text-sm font-medium">Name</label>
          <input
            id="cta-name"
            type="text"
            name="name"
            required
            autocomplete="name"
            placeholder="Jane Doe"
            class="w-full rounded-lg border border-edge bg-raised px-4 py-3 text-paper placeholder:text-dim focus:border-accent focus:outline-none"
          />
        </div>
        <div>
          <label for="cta-email" class="mb-1.5 block text-sm font-medium">Work email</label>
          <input
            id="cta-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="jane@company.com"
            class="w-full rounded-lg border border-edge bg-raised px-4 py-3 text-paper placeholder:text-dim focus:border-accent focus:outline-none"
          />
        </div>
        <div>
          <label for="cta-message" class="mb-1.5 block text-sm font-medium">
            What are you running, roughly what does it cost? <span class="text-dim">(optional)</span>
          </label>
          <textarea
            id="cta-message"
            name="message"
            rows="3"
            placeholder="e.g. GPT-4 + Claude, ~$20k/mo across a support bot and a doc pipeline"
            class="w-full rounded-lg border border-edge bg-raised px-4 py-3 text-paper placeholder:text-dim focus:border-accent focus:outline-none"></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-accent px-6 py-3 font-semibold text-ink transition-colors hover:bg-accent-hot disabled:cursor-not-allowed disabled:opacity-60"
        >
          Request my free audit
        </button>
        <p id="cta-error" hidden class="text-sm text-red-400">
          Something went wrong. Please try again, or email us directly below.
        </p>
      </form>
      <div id="cta-success" hidden class="mt-6 rounded-lg border border-edge bg-raised p-6 text-left">
        <p class="font-semibold">Request received.</p>
        <p class="mt-1 text-sm text-mist">
          We'll reply within one business day with a couple of questions and a time to talk.
        </p>
      </div>
      <p class="mt-3 text-xs text-dim">or email <a href="mailto:hello@spendrim.com" class="underline hover:text-paper">hello@spendrim.com</a></p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement;
  const success = document.getElementById('cta-success')!;
  const error = document.getElementById('cta-error')!;

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = form.querySelector('button')!;
    button.disabled = true;
    error.hidden = true;

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) throw new Error(`Formspree responded ${response.status}`);
      form.hidden = true;
      success.hidden = false;
    } catch {
      error.hidden = false;
      button.disabled = false;
    }
  });
</script>

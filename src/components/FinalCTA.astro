---
import SectionLabel from './SectionLabel.astro';
---

<section id="audit" class="py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6 sm:px-10">
    <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
      <div>
        <SectionLabel index="06" label="Book a free audit" />
        <h2 class="display mt-8 text-[2rem] leading-[1.05] sm:text-[2.5rem]">Tell us about your AI spend.</h2>
        <p class="mt-6 leading-relaxed text-ink-soft">
          Share a few details, then pick a time that works for you. We'll walk through your AI spend on a
          free 30-minute audit call.
        </p>
        <p class="mt-8 text-sm text-ink-faint">Prefer email?</p>
        <a href="mailto:contact@spendrim.com" class="font-semibold text-ink transition-colors hover:text-accent">
          contact@spendrim.com
        </a>

        <div class="mt-9 h-[220px] overflow-hidden rounded-lg sm:h-[300px]">
          <img
            src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=1200"
            alt="Team reviewing AI spend during an audit call"
            class="h-full w-full object-cover"
          />
        </div>
      </div>

      <div class="rounded-lg border border-rule bg-white p-9 sm:p-10">
        <form id="cta-form" action="https://formspree.io/f/mpqvpnje" method="POST" class="space-y-5">
          <input type="hidden" name="_subject" value="Free audit request - spendrim.com" />
          <div class="grid gap-5 sm:grid-cols-2">
            <div class="flex flex-col gap-1.5">
              <label for="cta-name" class="text-sm font-semibold text-ink-soft">Name</label>
              <input
                id="cta-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                class="rounded border border-rule bg-paper px-3 py-2.5 text-sm focus:border-accent focus:outline-none"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="cta-email" class="text-sm font-semibold text-ink-soft">Work email</label>
              <input
                id="cta-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                class="rounded border border-rule bg-paper px-3 py-2.5 text-sm focus:border-accent focus:outline-none"
              />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="cta-company" class="text-sm font-semibold text-ink-soft">Company</label>
            <input
              id="cta-company"
              type="text"
              name="company"
              autocomplete="organization"
              class="rounded border border-rule bg-paper px-3 py-2.5 text-sm focus:border-accent focus:outline-none"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="cta-spend" class="text-sm font-semibold text-ink-soft">Estimated monthly AI spend</label>
            <input
              id="cta-spend"
              type="text"
              name="monthly_spend"
              placeholder="e.g. $15,000"
              class="rounded border border-rule bg-paper px-3 py-2.5 text-sm placeholder:text-ink-faint focus:border-accent focus:outline-none"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="cta-message" class="text-sm font-semibold text-ink-soft">Anything we should know?</label>
            <textarea
              id="cta-message"
              name="message"
              rows="3"
              class="resize-none rounded border border-rule bg-paper px-3 py-2.5 text-sm focus:border-accent focus:outline-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="mt-2 w-full bg-ink px-6 py-3.5 text-sm font-semibold text-paper transition-colors hover:bg-accent disabled:cursor-not-allowed disabled:opacity-60"
          >
            Continue to pick a time
          </button>
          <p id="cta-error" hidden class="text-sm text-accent-deep">
            Something went wrong. Please try again, or email us directly.
          </p>
        </form>

        <div id="cta-schedule" hidden>
          <p class="display text-2xl">Thanks, <span id="cta-schedule-name">there</span>.</p>
          <p class="mt-3 leading-relaxed text-ink-soft">
            Now pick a slot that works for you for your free 30-minute audit call.
          </p>
          <div id="cal-inline" class="mt-6 min-h-[560px] w-full overflow-auto"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement;
  const schedule = document.getElementById('cta-schedule')!;
  const scheduleName = document.getElementById('cta-schedule-name')!;
  const error = document.getElementById('cta-error')!;

  let calReady = false;

  function loadCal() {
    (function (C: any, A: string, L: string) {
      let p = function (a: any, ar: any) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === 'string') {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ['initNamespace', namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window as any, 'https://app.cal.com/embed/embed.js', 'init');
  }

  function showScheduler(data: FormData) {
    const name = (data.get('name') as string) || '';
    const email = (data.get('email') as string) || '';
    const notes = (data.get('message') as string) || '';

    if (name) scheduleName.textContent = name.split(' ')[0];
    form.hidden = true;
    schedule.hidden = false;

    if (calReady) return;
    calReady = true;

    loadCal();
    const Cal = (window as any).Cal;
    Cal('init', 'audit', { origin: 'https://app.cal.com' });
    Cal.ns.audit('inline', {
      elementOrSelector: '#cal-inline',
      config: { layout: 'month_view', name, email, notes },
      calLink: 'bsimandoff',
    });
    Cal.ns.audit('ui', { hideEventTypeDetails: false, layout: 'month_view' });
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = form.querySelector('button')!;
    button.disabled = true;
    error.hidden = true;
    const data = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) throw new Error(`Formspree responded ${response.status}`);
      showScheduler(data);
    } catch {
      error.hidden = false;
      button.disabled = false;
    }
  });
</script>

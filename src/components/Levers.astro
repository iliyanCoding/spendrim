---
import SectionLabel from './SectionLabel.astro';

const levers = [
  {
    num: 'I',
    title: 'Prompt Caching Audit',
    body: "Find what's breaking your cache. One reordered system prompt or a timestamp in the wrong place can 10× your input costs.",
  },
  {
    num: 'II',
    title: 'Context Compaction',
    body: 'Prune stale tool results and redundant file reads before they compound. Agents carry less, think the same, cost far less.',
  },
  {
    num: 'III',
    title: 'Context Trimming',
    body: 'Kill redundant agent-loop calls — the retries, re-reads, and "let me check that again" cycles that quietly triple run costs.',
  },
  {
    num: 'IV',
    title: 'Budget Guardrails',
    body: 'Per-ticket and per-team spend limits with Slack alerts before you overspend — not an invoice autopsy after.',
  },
];
---

<section id="levers" class="border-t border-rule py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6 sm:px-10">
    <SectionLabel index="03" label="The levers" />
    <h2 class="display mt-8 max-w-2xl text-[2.25rem] leading-[1.05] sm:text-[3rem]">
      Four levers. Every one measured <em class="display-italic">before and after</em>.
    </h2>

    <div class="mt-14 grid gap-x-16 sm:grid-cols-2">
      {
        levers.map((l, i) => (
          <div
            class="border-t border-rule py-8"
          >
            <div class="flex items-baseline gap-4">
              <span class="display text-2xl text-accent" style="font-weight:500">{l.num}</span>
              <h3 class="display text-2xl">{l.title}</h3>
            </div>
            <p class="mt-3 max-w-md leading-relaxed text-ink-soft">{l.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

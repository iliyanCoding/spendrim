<section id="top" class="relative flex min-h-[560px] items-center overflow-hidden">
  <img
    src="https://images.pexels.com/photos/1181316/pexels-photo-1181316.jpeg?auto=compress&cs=tinysrgb&w=2000"
    alt=""
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-ink/95 via-ink/80 to-ink/50"></div>

  <div class="relative z-10 mx-auto w-full max-w-5xl px-6 py-28 sm:px-10 sm:py-32">
    <div class="max-w-xl">
      <p class="label text-[#f6b48e]">AI Cost Optimization &amp; Observability</p>
      <h1 class="display mt-6 text-[2.5rem] leading-[1.05] text-paper sm:text-[3.75rem]">
        Lower your AI spend by up to 30% and know where every dollar goes.
      </h1>
      <p class="mt-6 max-w-md text-lg leading-relaxed text-[#d7dbd2]">
        Spendrim finds exactly where AI spend disappears, fixes it in 30 days, and keeps watching after we
        leave, so the savings stick.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-6">
        <a
          href="#audit"
          class="bg-accent px-6 py-3.5 font-semibold text-paper transition-colors hover:bg-accent-deep"
        >
          Book a Free Audit
        </a>
        <a
          href="#offer"
          class="group inline-flex items-center gap-1.5 border-b border-paper pb-0.5 text-sm font-semibold text-paper transition-colors hover:border-accent hover:text-accent"
        >
          See the 30-day offer
          <span class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

---
import SectionLabel from './SectionLabel.astro';

const rows = [
  { ticket: 'ENG-1482', feature: 'PDF ingestion agent', dev: 'mara', runs: 214, cost: '$4,812', flag: true },
  { ticket: 'ENG-1503', feature: 'Support autoresponder', dev: 'dev_k', runs: 1861, cost: '$2,304' },
  { ticket: 'ENG-1477', feature: 'Search reranking', dev: 'jonas', runs: 903, cost: '$1,187' },
  { ticket: 'ENG-1519', feature: 'Changelog summarizer', dev: 'mara', runs: 122, cost: '$391' },
  { ticket: 'ENG-1467', feature: 'Onboarding copilot', dev: 'ana', runs: 388, cost: '$246' },
];
---

<section id="attribution" class="border-t border-rule py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6 sm:px-10">
    <SectionLabel index="02" label="The core wedge" />

    <div class="mt-8 grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <div>
        <h2 class="display max-w-md text-[2.25rem] leading-[1.05] sm:text-[3rem]">
          Every run tied to the <em class="display-italic">ticket</em> that triggered it.
        </h2>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-ink-soft">
          See exact spend per ticket, per developer, per feature — so cost conversations stop being
          guesses and start being line items.
        </p>
        <ul class="mt-8 space-y-3.5">
          {
            [
              'Which features actually pay for their inference',
              'Which agent loops re-read the same context 40 times',
              'Which initiatives to kill, cap, or double down on',
            ].map((t) => (
              <li class="flex items-baseline gap-3 border-b border-rule pb-3.5 text-ink">
                <span class="text-accent">&mdash;</span>
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Ledger table -->
      <figure>
        <div class="flex items-baseline justify-between border-b-2 border-ink pb-2">
          <span class="label text-ink-faint">Spend by ticket</span>
          <span class="num text-xs text-ink-faint">last 30 days</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full min-w-[440px] text-left text-sm">
            <thead>
              <tr class="label text-ink-faint">
                <th class="py-2.5 pr-3 font-medium" style="font-size:0.62rem">Ticket</th>
                <th class="py-2.5 pr-3 font-medium" style="font-size:0.62rem">Feature</th>
                <th class="py-2.5 pr-3 font-medium" style="font-size:0.62rem">Dev</th>
                <th class="py-2.5 pr-3 text-right font-medium" style="font-size:0.62rem">Runs</th>
                <th class="py-2.5 text-right font-medium" style="font-size:0.62rem">Spend</th>
              </tr>
            </thead>
            <tbody>
              {
                rows.map((r) => (
                  <tr class="border-t border-rule">
                    <td class="num py-3 pr-3 text-ink">{r.ticket}</td>
                    <td class="py-3 pr-3 text-ink-soft">{r.feature}</td>
                    <td class="num py-3 pr-3 text-ink-soft">@{r.dev}</td>
                    <td class="num py-3 pr-3 text-right text-ink-soft">{r.runs.toLocaleString('en-US')}</td>
                    <td class={`num py-3 text-right ${r.flag ? 'font-semibold text-accent' : 'text-ink'}`}>{r.cost}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <figcaption class="mt-3 flex items-baseline gap-3 border-t border-rule pt-3">
          <span class="num text-xs text-accent">Table 1</span>
          <span class="text-xs leading-relaxed text-ink-faint">
            Sample view. <span class="num text-ink">ENG-1482</span> flagged — <span class="num text-accent">78%</span> of its spend traced to a cache-busting system prompt.
          </span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

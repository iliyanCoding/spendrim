---
import Accordion from './Accordion.astro';
import SectionLabel from './SectionLabel.astro';

const items = [
  {
    q: 'How is the 30-day sprint priced?',
    a: "It's a fixed price, quoted after the free audit, tied to the size of your current spend and the number of levers we find. No hourly billing.",
  },
  {
    q: "What if the audit doesn't find much to fix?",
    a: 'Then we tell you that directly and you walk away with a clear picture of your spend at no cost, no pressure to buy the sprint.',
  },
  {
    q: 'Do you need access to our production systems?',
    a: "We need read access to usage and billing data, plus a way to ship configuration changes with your team's sign-off. We scope exact access during the proposal.",
  },
  {
    q: 'What happens after the 30 days?',
    a: 'Your dashboard and alerts keep running. You can bring monitoring in-house, or keep us on a simple monthly retainer to keep watching.',
  },
  {
    q: 'Who is this for?',
    a: "Teams spending meaningfully on LLM APIs, inference infrastructure, or AI tooling who suspect, but can't yet prove, that some of it is waste.",
  },
];
---

<section id="faq" class="border-t border-rule py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-6 sm:px-10">
    <SectionLabel index="05" label="Questions" />
    <h2 class="display mt-8 text-[2.25rem] leading-[1.05] sm:text-[3rem]">Questions</h2>
    <div class="mt-12">
      <Accordion items={items} />
    </div>
  </div>
</section>

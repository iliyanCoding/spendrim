---
import SectionLabel from './SectionLabel.astro';

const weeks = [
  {
    label: 'Week 01',
    name: 'Scout',
    items: ['Full spend audit across providers', 'Waste map: where every wasted dollar goes', 'Signed savings estimate, in writing'],
  },
  {
    label: 'Week 02',
    name: 'Execute',
    items: ['All four levers implemented', 'Done-for-you — your team keeps shipping', 'Before / after measured per change'],
  },
  {
    label: 'Week 03',
    name: 'Handoff',
    items: ['Attribution dashboard live', 'Team training on cost-aware patterns', '30-day monitoring begins'],
  },
];
---

<section id="offer" class="border-t border-rule py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6 sm:px-10">
    <SectionLabel index="04" label="The offer" />
    <h2 class="display mt-8 text-[2.25rem] leading-[1.05] sm:text-[3rem]">
      AI Spend Reset — a <span class="num text-[0.85em]">21</span>-day sprint.
    </h2>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
      Three weeks from black box to line items. Fixed scope, fixed timeline, measured outcome.
    </p>

    <div class="mt-14 grid gap-x-14 gap-y-10 sm:grid-cols-3">
      {
        weeks.map((w, i) => (
          <div class="border-t-2 border-ink pt-5">
            <div class="flex items-baseline justify-between">
              <span class="display text-xl">{w.name}</span>
              <span class="num text-xs text-ink-faint">{w.label}</span>
            </div>
            <ul class="mt-5 space-y-3">
              {w.items.map((item) => (
                <li class="flex items-baseline gap-3 border-t border-rule pt-3 text-sm leading-relaxed text-ink-soft">
                  <span class="text-accent">&mdash;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-16 border-t border-b border-rule py-10 text-center">
      <p class="display mx-auto max-w-2xl text-[1.75rem] leading-[1.2] sm:text-[2.25rem]">
        Hit the agreed savings figure in <span class="num text-[0.8em]">30</span> days —
        <em class="display-italic text-accent"> or you don't pay.</em>
      </p>
    </div>
  </div>
</section>

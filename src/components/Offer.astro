---
import { Icon } from 'astro-icon/components';

const weeks = [
  {
    label: 'Week 1',
    name: 'Scout',
    icon: 'lucide:search',
    items: ['Full spend audit across providers', 'Waste map: where every wasted dollar goes', 'Signed savings estimate, in writing'],
  },
  {
    label: 'Week 2',
    name: 'Execute',
    icon: 'lucide:wrench',
    items: ['All four levers implemented', 'Done-for-you — your team keeps shipping', 'Before/after measured per change'],
  },
  {
    label: 'Week 3',
    name: 'Handoff',
    icon: 'lucide:flag',
    items: ['Attribution dashboard live', 'Team training on cost-aware patterns', '30-day monitoring begins'],
  },
];
---

<section id="offer" class="border-t border-edge py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-accent" data-reveal>The offer</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl" data-reveal>
      AI Spend Reset — a 21-day sprint
    </h2>
    <p class="mt-4 max-w-2xl text-lg text-mist" data-reveal style="--reveal-delay: 100ms">
      Three weeks from black box to line items. Fixed scope, fixed timeline, measured outcome.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        weeks.map((w, i) => (
          <div class="relative rounded-xl border border-edge bg-surface p-7" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-widest text-dim">{w.label}</span>
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-raised text-accent">
                <Icon name={w.icon} class="h-4 w-4" />
              </div>
            </div>
            <h3 class="mt-3 text-xl font-semibold">{w.name}</h3>
            <ul class="mt-4 space-y-2.5 text-sm leading-relaxed text-mist">
              {w.items.map((item) => (
                <li class="flex items-start gap-2.5">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-8 flex flex-col items-center gap-3 rounded-xl border border-accent/40 bg-accent/5 px-8 py-7 text-center sm:flex-row sm:justify-center sm:gap-4"
      data-reveal
    >
      <Icon name="lucide:badge-check" class="h-6 w-6 shrink-0 text-accent" />
      <p class="text-lg font-semibold">
        Hit the agreed savings % in 30 days — <span class="text-accent">or you don't pay.</span>
      </p>
    </div>
  </div>
</section>

---
import Logo from './Logo.astro';
import MobileMenu from './MobileMenu.svelte';

const links = [
  { href: '#problem', label: 'The problem' },
  { href: '#attribution', label: 'Attribution' },
  { href: '#levers', label: 'The levers' },
  { href: '#offer', label: 'The sprint' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-edge bg-ink/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
    <a href="#top" class="flex items-center gap-2.5" aria-label="Spendrim home">
      <Logo class="h-7 w-7" />
      <span class="text-lg font-semibold tracking-tight">Spendrim</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
      {links.map((l) => <a href={l.href} class="text-sm text-mist transition-colors hover:text-paper">{l.label}</a>)}
    </nav>

    <div class="hidden md:block">
      <a
        href="#book"
        class="rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-ink transition-colors hover:bg-accent-hot"
      >
        Book a Free Waste Audit
      </a>
    </div>

    <MobileMenu client:media="(max-width: 767px)" links={links} />
  </div>
</header>

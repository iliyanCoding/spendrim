---
import Logo from './Logo.astro';
import MobileMenu from './MobileMenu.astro';

const links = [
  { href: '#problem', label: 'The problem' },
  { href: '#attribution', label: 'Attribution' },
  { href: '#levers', label: 'The levers' },
  { href: '#offer', label: 'The sprint' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-rule bg-paper">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6 sm:px-10">
    <a href="#top" class="flex items-center gap-2.5" aria-label="Spendrim home">
      <Logo class="h-7 w-7" />
      <span class="display text-xl" style="font-weight:520">Spendrim</span>
    </a>

    <nav class="hidden items-center gap-9 md:flex" aria-label="Main">
      {links.map((l) => <a href={l.href} class="text-sm text-ink-soft transition-colors hover:text-accent">{l.label}</a>)}
    </nav>

    <div class="hidden md:block">
      <a
        href="#book"
        class="group inline-flex items-center gap-1.5 border-b border-accent pb-0.5 text-sm font-medium text-accent transition-colors hover:text-accent-deep"
      >
        Request an audit
        <span class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
      </a>
    </div>

    <MobileMenu links={links} />
  </div>
</header>

---
import MobileMenu from './MobileMenu.astro';

const links = [
  { href: '#tickets', label: 'Ticket Costs' },
  { href: '#offer', label: 'The Offer' },
  { href: '#process', label: 'How It Works' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-rule bg-paper">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6 sm:px-10">
    <a href="#top" aria-label="Spendrim home">
      <img src="/spendrim-logo.png" alt="Spendrim" class="h-8 w-auto" />
    </a>

    <nav class="hidden items-center gap-9 md:flex" aria-label="Main">
      {links.map((l) => <a href={l.href} class="text-sm text-ink-soft transition-colors hover:text-accent">{l.label}</a>)}
    </nav>

    <div class="hidden md:block">
      <a
        href="#audit"
        class="bg-ink px-5 py-2.5 text-sm font-semibold text-paper transition-colors hover:bg-accent"
      >
        Book a Free Audit
      </a>
    </div>

    <MobileMenu links={links} />
  </div>
</header>

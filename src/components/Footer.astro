---
const year = new Date().getFullYear();
---

<footer class="border-t border-rule">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-6 py-10 sm:px-10">
    <img src="/spendrim-logo.png" alt="Spendrim" class="h-5 w-auto" />
    <p class="text-sm text-ink-faint">
      &copy; {year} Spendrim. <a href="mailto:contact@spendrim.com" class="hover:text-accent">contact@spendrim.com</a>
    </p>
  </div>
</footer>

---
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-edge py-10">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-5 sm:flex-row sm:px-8">
    <div class="flex items-center gap-2.5">
      <Logo class="h-6 w-6" />
      <span class="font-semibold">Spendrim</span>
      <span class="text-sm text-dim">© {year}</span>
    </div>
    <div class="flex items-center gap-6 text-sm text-mist">
      <a href="mailto:hello@spendrim.com" class="transition-colors hover:text-paper">hello@spendrim.com</a>
      <a href="https://x.com/spendrim" target="_blank" rel="noopener" class="transition-colors hover:text-paper">X</a>
      <a href="https://linkedin.com/company/spendrim" target="_blank" rel="noopener" class="transition-colors hover:text-paper">LinkedIn</a>
    </div>
  </div>
</footer>

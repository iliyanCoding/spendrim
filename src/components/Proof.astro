import Counter from './Counter.astro';
---

<section id="results" class="border-t border-edge py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-accent" data-reveal>Results</p>
    <h2 class="mt-3 max-w-2xl text-3xl font-semibold tracking-tight sm:text-4xl" data-reveal>
      Nothing but net savings.
    </h2>

    <div class="mt-12 grid gap-6 rounded-xl border border-edge bg-surface p-8 sm:grid-cols-2 sm:p-10" data-reveal>
      <div class="text-center">
        <p class="text-4xl font-semibold text-success sm:text-5xl">
          <Counter value={43} suffix="%" />
        </p>
        <p class="mt-2 text-sm text-mist">average savings delivered</p>
      </div>
      <div class="text-4xl text-center font-semibold sm:text-5xl">
        <p class="text-4xl font-semibold sm:text-5xl">
          <Counter value={21} suffix=" days" />
        </p>
        <p class="mt-2 text-sm text-mist">audit to live dashboard</p>
      </div>
    </div>

    <figure class="mx-auto mt-12 max-w-3xl text-center" data-reveal style="--reveal-delay: 100ms">
      <blockquote class="text-xl leading-relaxed text-paper sm:text-2xl">
        “We thought our agent infra was tuned. Spendrim found a cache-busting header that was costing us $11K a month
        - in the first week.”
      </blockquote>
      <figcaption class="mt-4 text-sm text-dim">Placeholder quote - VP Engineering, Series B SaaS</figcaption>
    </figure>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-12 gap-y-6 opacity-50" data-reveal style="--reveal-delay: 200ms">
      {
        ['ACME AI', 'NORTHBEAM', 'VECTORLY', 'PARSEC', 'QUOTIENT'].map((logo) => (
          <span class="text-sm font-semibold tracking-[0.2em] text-mist">{logo}</span>
        ))
      }
    </div>
  </div>
</section>

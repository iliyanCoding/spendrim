---
import SectionLabel from './SectionLabel.astro';

const bonuses = [
  { title: 'Batch API review', body: 'Move offline workloads to batch pricing — often a flat 50% cut on eligible traffic.' },
  { title: 'Output compression', body: 'Tighter schemas and shorter completions where verbosity adds nothing but tokens.' },
  { title: 'Developer training', body: 'Your team learns the cost-aware patterns so the savings stick after we leave.' },
  { title: '30-day monitoring', body: 'We watch the dashboard after launch and flag regressions before they compound.' },
  { title: 'Discounted quarterly audits', body: 'Models and usage change. Keep the waste map current at a returning-client rate.' },
];
---

<section id="bonuses" class="border-t border-rule py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6 sm:px-10">
    <SectionLabel index="05" label="Also included" />
    <h2 class="display mt-8 max-w-2xl text-[2.25rem] leading-[1.05] sm:text-[3rem]">
      Every sprint ships with <em class="display-italic">the assists</em>.
    </h2>

    <div class="mt-14 grid gap-x-16 sm:grid-cols-2">
      {
        bonuses.map((b, i) => (
          <div class="flex items-baseline gap-5 border-t border-rule py-6">
            <span class="num text-sm text-accent">0{i + 1}</span>
            <div>
              <h3 class="display text-xl">{b.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{b.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

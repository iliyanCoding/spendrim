---
import { Icon } from 'astro-icon/components';

const bonuses = [
  { icon: 'lucide:layers', title: 'Batch API review', body: 'Move offline workloads to batch pricing — often a flat 50% cut on eligible traffic.' },
  { icon: 'lucide:minimize-2', title: 'Output compression', body: 'Tighter schemas and shorter completions where verbosity adds nothing but tokens.' },
  { icon: 'lucide:graduation-cap', title: 'Developer training', body: 'Your team learns the cost-aware patterns so the savings stick after we leave.' },
  { icon: 'lucide:activity', title: '30-day monitoring', body: 'We watch the dashboard after launch and flag regressions before they compound.' },
  { icon: 'lucide:repeat', title: 'Discounted quarterly audits', body: 'Models and usage change. Keep the waste map current at a returning-client rate.' },
];
---

<section id="bonuses" class="border-t border-edge py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-accent" data-reveal>Included</p>
    <h2 class="mt-3 max-w-2xl text-3xl font-semibold tracking-tight sm:text-4xl" data-reveal>
      Every sprint ships with the assists.
    </h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        bonuses.map((b, i) => (
          <div class="flex items-start gap-4 rounded-xl border border-edge bg-surface p-6" data-reveal style={`--reveal-delay: ${i * 60}ms`}>
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-raised text-accent">
              <Icon name={b.icon} class="h-4.5 w-4.5" />
            </div>
            <div>
              <h3 class="font-semibold">{b.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-mist">{b.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
